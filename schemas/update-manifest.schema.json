{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "repository", "tag", "asset", "sha256Asset", "sha256", "size", "downloadNodes"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" },
    "channel": { "type": "string" },
    "repository": { "type": "string" },
    "tag": { "type": "string" },
    "asset": { "type": "string" },
    "sha256Asset": { "type": "string" },
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "size": { "type": "integer", "minimum": 0 },
    "downloadUrl": { "type": "string", "format": "uri" },
    "sha256Url": { "type": "string", "format": "uri" },
    "releaseNotesUrl": { "type": "string", "format": "uri" },
    "releaseNotes": { "type": "string" },
    "downloadNodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/downloadNode" },
      "contains": {
        "type": "object",
        "properties": {
          "id": { "const": "github-direct" },
          "template": { "const": "{url}" },
          "priority": { "const": 1000 },
          "enabled": { "const": true }
        },
        "required": ["id", "template", "priority", "enabled"]
      }
    }
  },
  "$defs": {
    "downloadNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "template", "priority", "enabled"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "template": {
          "type": "string",
          "pattern": "^(\\{url\\}|https://[^\\s{}]+/\\{url\\})$"
        },
        "priority": { "type": "integer", "minimum": 0 },
        "enabled": { "type": "boolean" }
      }
    }
  }
}
